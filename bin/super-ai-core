#!/usr/bin/env php
<?php

/**
 * super-ai-core — unified CLI for calling any configured backend.
 *
 * Examples:
 *   super-ai-core call "Hello" --backend=anthropic_api --model=claude-sonnet-4-5-20241022
 *   super-ai-core call "Hello" --backend=claude_cli
 *   super-ai-core call "Hello" --backend=codex_cli
 *   super-ai-core call "Hello" --backend=superagent
 *   super-ai-core list-backends
 */

$autoloadCandidates = [
    __DIR__ . '/../vendor/autoload.php',        // when developing super-ai-core
    __DIR__ . '/../../../autoload.php',         // when installed as dependency
    __DIR__ . '/../../../../vendor/autoload.php',
];

foreach ($autoloadCandidates as $candidate) {
    if (file_exists($candidate)) {
        require $candidate;
        break;
    }
}

use SuperAICore\Console\Application;

$app = new Application();
$app->run();
